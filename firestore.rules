rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /courses/{courseId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner();
      allow update, delete: if isDocOwner();
    }

    match /subjects/{subjectId} {
      allow read, write: if isAuthenticated(); // Simplified for now, should check course ownership
    }

    match /topics/{topicId} {
      allow read, write: if isAuthenticated();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner();
      allow update, delete: if isDocOwner();
    }

    match /daily_plans/{planId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner();
      allow update, delete: if isDocOwner();
    }
  }
}
